rules_version = '2';
// ==========================================================================
// VETOR — Regras de segurança do Firestore (rev. 3)
// ==========================================================================
// IMPORTANTE: a coleção `usuarios` usa o e-mail como ID do documento.
// As regras são intencionalmente simples para que o avaliador estático do
// Firestore consiga validar queries (em particular array-contains em resp_emails).
// ==========================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- HELPERS ----------------
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function userDocPath() {
      return /databases/$(database)/documents/usuarios/$(userEmail());
    }

    function userDocExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function userPapel() {
      return get(userDocPath()).data.papel;
    }

    function isSuperAdmin() {
      return userDocExists() && userPapel() == 'super-admin';
    }

    function isGestorArea(areaId) {
      return userDocExists() &&
             exists(/databases/$(database)/documents/areas_estrategicas/$(areaId)) &&
             userEmail() in get(/databases/$(database)/documents/areas_estrategicas/$(areaId)).data.gestores;
    }

    // Verifica se o usuário aparece em resp_emails da tarefa.
    // Usa get(...) com default [] para tolerar tarefas legadas sem o campo.
    function isExecutorTask(taskData) {
      return userEmail() in taskData.get('resp_emails', []);
    }

    // ---------------- COLEÇÃO: usuarios ----------------
    // ID do documento = e-mail do usuário (lowercase).
    match /usuarios/{userId} {
      // Qualquer usuário autenticado (mesmo antes do bootstrap) lê /usuarios.
      // Necessário para o login funcionar e para o tradutor de e-mail→nome.
      allow read: if isSignedIn();

      // Create: super-admin OU qualquer credenciado criando um MEMBRO comum.
      // (Gestores de área podem credenciar novos membros; nunca criar super-admin.)
      allow create: if isSuperAdmin() || (
        userDocExists() &&
        request.resource.data.papel == 'membro'
      );

      // Exclui: somente super-admin.
      allow delete: if isSuperAdmin();

      // Update:
      //   - Super-admin: tudo.
      //   - Próprio usuário (userId == userEmail()): apenas o campo 'telefone'.
      allow update: if isSuperAdmin() || (
        isSignedIn() &&
        userId == userEmail() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['telefone'])
      );
    }

    // ---------------- COLEÇÃO: areas_estrategicas ----------------
    match /areas_estrategicas/{areaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // ---------------- COLEÇÃO: tarefas ----------------
    match /tarefas/{taskId} {
      // Read — três caminhos. O caminho do executor é o mais barato e fica primeiro.
      allow read: if isSignedIn() && (
        isExecutorTask(resource.data) ||
        isSuperAdmin() ||
        (resource.data.area != null && isGestorArea(resource.data.area))
      );

      // Create — super-admin ou gestor da área de destino.
      allow create: if isSignedIn() && (
        isSuperAdmin() ||
        (request.resource.data.area != null && isGestorArea(request.resource.data.area))
      ) &&
      request.resource.data.text is string &&
      request.resource.data.project is string &&
      request.resource.data.status in ['fazer','andamento','aprovacao','concluido'];

      // Update — gestor pleno faz qualquer coisa; executor pode:
      //   • mudar status (sem concluir — só fazer/andamento/aprovacao)
      //   • adicionar entradas no historico
      //   • adicionar/editar comentarios (na timeline de Atividade)
      //   • marcar subtarefas como concluídas (toggle)
      //   • adicionar/remover links de referência
      // Mudanças estruturais (subtarefa nova/removida, dependência, mudança de
      // equipe, prioridade, datas, título) ficam restritas a gestor pleno.
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (resource.data.area != null && isGestorArea(resource.data.area)) ||
        (
          isExecutorTask(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status','historico','comentarios','subtarefas','links']) &&
          request.resource.data.status in ['fazer','andamento','aprovacao']
        )
      );

      // Delete — super-admin ou gestor da área.
      allow delete: if isSignedIn() && (
        isSuperAdmin() ||
        (resource.data.area != null && isGestorArea(resource.data.area))
      );
    }

    // ---------------- COLEÇÃO: ai_logs ----------------
    match /ai_logs/{logId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.userEmail == userEmail());
      allow write: if false; // só admin SDK
    }

    // ---------------- COLEÇÃO: briefings_diarios ----------------
    match /briefings_diarios/{id} {
      allow read: if isSuperAdmin();
      allow write: if false; // só admin SDK
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
